rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidScore() {
      return request.resource.data.keys().hasOnly([
          'playerCode',
          'answer',
          'attempts',
          'seconds',
          'won',
          'createdAt'
        ])
        && request.resource.data.playerCode is string
        && request.resource.data.playerCode.matches('^P-[A-Z2-9]{6}$')
        && request.resource.data.answer is string
        && request.resource.data.answer.matches('^[1-9]{4}$')
        && request.resource.data.attempts is int
        && request.resource.data.attempts >= 1
        && request.resource.data.attempts <= 99
        && request.resource.data.seconds is int
        && request.resource.data.seconds >= 0
        && request.resource.data.seconds <= 3600
        && request.resource.data.won is bool
        && request.resource.data.createdAt is string;
    }

    match /bullsAndCowsScores/{scoreId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidScore();
      allow update, delete: if false;
    }
  }
}
